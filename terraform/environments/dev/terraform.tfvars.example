# Dev Environment - Terraform Variables
# Copy this to terraform.tfvars and customize

aws_region  = "us-east-1"
environment = "dev"

# VPC
vpc_cidr           = "10.0.0.0/16"
az_count           = 2
single_nat_gateway = true # Set to false for HA in production

# EKS
cluster_version            = "1.33"
system_node_instance_types = ["t3.medium"]
system_node_min_size       = 2
system_node_max_size       = 4
system_node_desired_size   = 2

# Bastion
bastion_instance_type = "t3.micro" # Free tier eligible
